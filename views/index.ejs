<!DOCTYPE html>
<html>
<head>
  <title>Product Catalog</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <h1>Product Catalog</h1>
  <a href="/add" class="btn">Add New Product</a>
  <table>
    <thead>
      <tr><th>ID</th><th>Name</th><th>Price (RM)</th><th>Category</th><th>Action</th></tr>
    </thead>
    <tbody>
      <% products.forEach(p => { %>
        <tr>
          <td><%= p.id %></td>
          <td><%= p.name %></td>
          <td><%= p.price.toFixed(2) %></td>
          <td><%= p.category %></td>
          <td><a href="/product/<%= p.id %>">View</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
